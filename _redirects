# _redirects file for Cloudflare Pages / Netlify
# Handles URL redirects for SEO (avoid duplicate content)

# Force non-www to www (or vice versa — pick one, stick with it)
# Uncomment the one you want:
# https://www.notepadonline.app/*  https://notepadonline.app/:splat  301
# https://notepadonline.app/*  https://www.notepadonline.app/:splat  301

# Common misspellings / old URLs redirect to homepage
/index.html        /           301
/home               /           301
/notepad            /           301
/editor             /           301
/note               /           301

# Blog clean URLs (when you expand to separate pages later)
/blog               /#blog      302
